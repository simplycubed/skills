# macOS
.DS_Store

# Node
node_modules/
npm-debug.log*
pnpm-debug.log*

# NOTE: .claude-plugin/marketplace.json and catalog.json are GENERATED but COMMITTED
# (Claude Code reads marketplace.json from the repo; catalog.json feeds the storefront).
# CI regenerates them and a no-drift check fails the build if they don't match config/skills/.

# Local env / scan working dirs
.env
.env.local
/tmp/
/.scan-work/
# R2 upload staging (snapshot blobs are packed here, then uploaded to R2 by the sync Action)
/.r2-staging/
# Miner dry-run output (discover → phase1 candidate list; uploaded as a CI artifact, not committed)
/candidates.json
