{
  "name": "@simplycubed/skills",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "SimplyCubed Skills marketplace: schema, validation, and generators for certified Agent Skills (the open, cross-tool SKILL.md format).",
  "license": "MIT",
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "validate": "node scripts/validate-skills.mjs",
    "certify": "node scripts/certify.mjs",
    "gate:selftest": "node scripts/gate-selftest.mjs",
    "unit:selftest": "node scripts/unit-selftest.mjs",
    "r2:selftest": "node scripts/r2-selftest.mjs",
    "r2:migrate": "node scripts/r2-migrate.mjs",
    "r2:migrate:check": "node scripts/r2-migrate.mjs --dry-run",
    "r2:migrate:verify": "node scripts/r2-migrate.mjs --verify",
    "r2:sync": "node scripts/r2-migrate.mjs --sync",
    "fetch": "node scripts/fetch.mjs",
    "scan": "node scripts/scan.mjs",
    "scan:selftest": "node scripts/scan-selftest.mjs",
    "certify:active": "node scripts/certify-active.mjs",
    "snapshot": "node scripts/snapshot.mjs",
    "snapshot:check": "node scripts/snapshot-check.mjs",
    "snapshot:selftest": "node scripts/snapshot-selftest.mjs",
    "workflow:lint": "node scripts/workflow-lint.mjs",
    "bloat:guard": "node scripts/bloat-guard.mjs",
    "clean": "rm -rf .scan-work .r2-staging",
    "gate": "node scripts/gate.mjs",
    "revoke": "node scripts/revoke.mjs",
    "revoke:selftest": "node scripts/revoke-selftest.mjs",
    "generate": "node scripts/generate.mjs",
    "generate:check": "node scripts/generate.mjs --check",
    "generate:selftest": "node scripts/generate-selftest.mjs",
    "catalog:check": "node scripts/validate-catalog.mjs"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "js-yaml": "^4.1.0"
  }
}
